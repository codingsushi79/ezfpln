# Required: 32+ character secret for encrypted session cookies
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars-long

# Optional: SQLite path for local accounts (default: ./data/ezflpln.db)
# DATABASE_PATH=

# Public site URL (no trailing slash). Must match Navigraph app redirect.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Navigraph OAuth (request client id/secret from Navigraph)
NAVIGRAPH_CLIENT_ID=
NAVIGRAPH_CLIENT_SECRET=
